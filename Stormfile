// Stormfile for Storm-Knell (sk)
cc: /usr/bin/gcc
linker: mold
cflags: -std=c23 -Wall -Werror -Wextra -pedantic
lflags: -lpthread -lxxhash

major: 0
minor: 4
patch: 2


codegen src/core/sk_config.h {
    literal: "#pragma once"

    define: SK_VERSION_MAJOR major
    define: SK_VERSION_MINOR minor
    define: SK_VERSION_PATCH patch

    define: SK_VERSION_STRING "major.minor.patch"
    define: SK_COMPILED_GCC __gcc__
    define: SK_COMPILED_CLANG __clang__
}

target skdbg
{
    out: skdbg
    mode: debug

    cflags:: -g -pthread -DDEBUG

    exclude:
    build/
    test/
    docs/
    sources:
    src/
    external/vx/src/
    includes:
    -Isrc
    -Isrc/core
    -Isrc/core/cli
    -Isrc/core/commands
    -Isrc/core/dsl
    -Isrc/core/hash
    -Isrc/core/invoke
    -Isrc/core/memory
    -Isrc/core/sk_cache
    -Isrc/core/util
    -Iexternal/vx/include

    install: ~/.local/bin
}

target sk
{
    out: sk
    mode: release

    print: __sk_version__

    if (__clang__)
    {
        cflags:: -Wloop-analysis -Wthread-safety-pointer -Wdocumentation -Wunicode-whitespace
    }

    if(__has_mbmi__){
        cflags:: -mbmi
    }

    cflags::
    -O2 -march=native
    -mlzcnt -pthread
    -Wvla -Wcast-align
    -Wredundant-decls
    -Wmissing-noreturn
    -fvisibility=hidden

    if(full_opt)
    {
        print: "Toggled full optimizations: cflags::  -O3 -flto=auto lflags::  -flto=auto -Wl,-O1 -Wl,--as-needed"
        cflags::  -O3 -flto=auto
        lflags::  -flto=auto -Wl,-O1 -Wl,--as-needed
    }


    exclude:
    build/
    test/
    docs/
    sources:
    src/
    external/vx/src/
    includes:
    -Isrc
    -Isrc/core
    -Isrc/core/cli
    -Isrc/core/commands
    -Isrc/core/dsl
    -Isrc/core/hash
    -Isrc/core/invoke
    -Isrc/core/memory
    -Isrc/core/sk_cache
    -Isrc/core/util
    -Iexternal/vx/include

    install: ~/.local/bin
}
