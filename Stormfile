// Stormfile for Storm-Knell (sk)
cc: /usr/bin/gcc
cflags: -Wall -Werror -Wextra -pedantic
lflags: -lxxhash

if(bootstrap)
{
    print: "Building bootstrapped sk..."
    cflags:: -std=c2x
}
else
{
    cflags:: -std=c23
    linker:  mold
}

if(__os__ == "linux")
{
    print: "Linux detected"
    defines:: -D_GNU_SOURCE
    cflags::  -pthread
    lflags::  -lpthread
}

// You can set the desired global arena size by uncommenting this define and re-building
// Default size is 128 MB, reserverd not allocated.
// defines: -DSK_ARENA_SIZE_MB=256

major: 0
minor: 5
patch: 3


codegen src/core/sk_config.h {
    literal: "#pragma once"

    define: SK_VERSION_MAJOR major
    define: SK_VERSION_MINOR minor
    define: SK_VERSION_PATCH patch

    define: SK_VERSION_STRING "major.minor.patch"
    define: SK_COMPILED_GCC __gcc__
    define: SK_COMPILED_CLANG __clang__
}

target sk
{
    out: sk
    mode: release

    print: __sk_version__

    if (__clang__)
    {
        print: "cc: clang"
        cflags:: -Wloop-analysis -Wthread-safety-pointer -Wdocumentation -Wunicode-whitespace
    }

    if(__has_mbmi__){
        cflags:: -mbmi
    }

    cflags::
        -O2 -march=native
        -mlzcnt -Wvla -Wcast-align
        -Wredundant-decls
        -Wmissing-noreturn
        -fvisibility=hidden
        -DNDEBUG

    if(full_opt)
    {
        print: "Toggled full optimizations: cflags::  -O3 -flto=auto lflags::  -flto=auto -Wl,-O1 -Wl,--as-needed"
        cflags::  -O3 -flto=auto
        lflags::  -flto=auto -Wl,-O1 -Wl,--as-needed
    }


    exclude:
        build/
        test/
        docs/
    sources:
        src/
        external/vx/src/
    includes:
        -Isrc
        -Isrc/core
        -Isrc/core/cli
        -Isrc/core/commands
        -Isrc/core/dsl
        -Isrc/core/hash
        -Isrc/core/invoke
        -Isrc/core/memory
        -Isrc/core/sk_cache
        -Isrc/core/util
        -Iexternal/vx/include

    // Installs the binary directly to the desired path
    install: ~/.local/bin
}

// sk strike --set=sk_debug
if(sk_debug)
{
    cc: /usr/bin/clang // will override gcc from top and use clang for this target
    linker: lld
    target skdbg
    {
        out: skdbg
        mode: debug

        // defines also can be set in cflags
        cflags:: -g -DDEBUG

        exclude:
            build/
            test/
            docs/
        sources:
            src/
            external/vx/src/
        includes:
            -Isrc
            -Isrc/core
            -Isrc/core/cli
            -Isrc/core/commands
            -Isrc/core/dsl
            -Isrc/core/hash
            -Isrc/core/invoke
            -Isrc/core/memory
            -Isrc/core/sk_cache
            -Isrc/core/util
            -Iexternal/vx/include

        install: ~/.local/bin
    }
}
